{
    "pipeline": {
        "run_date": null,
        "env": "staging",
        "log_level": "INFO",
        "modules": [
            "module1",
            "module2",
            "module3"
        ],
        "fail_fast": true,
        "max_retries": 3,
        "retry_delay_seconds": 30
    },
    "spark": {
        "master": "local[*]",
        "driver_memory": "4g",
        "executor_memory": "8g",
        "executor_cores": 4,
        "shuffle_partitions": 200,
        "adaptive_enabled": true
    },
    "minio": {
        "endpoint": "http://minio.internal.company.com:9000",
        "path_style_access": true,
        "bucket_bronze": "bronze",
        "bucket_silver": "silver",
        "bucket_gold": "gold"
    },
    "postgres": {
        "host": "db.internal.company.com",
        "port": 5432,
        "database": "oltp_db",
        "fetch_size": 10000
    },
    "delta": {
        "vacuum_retention_hours": 168,
        "optimize_target_file_size": 134217728,
        "merge_schema": false
    },
    "dynatrace": {
        "enabled": true,
        "cluster_id": "spark-pipeline-prod"
    }
}